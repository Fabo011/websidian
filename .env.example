# Server
PORT=3065

# Comma separated list is not needed; single secret used to sign JWTs.
# Generate a strong random value, e.g. `openssl rand -hex 32`
JWT_SECRET=change-me-please-use-a-long-random-string

# JWT lifetime for the authenticated session cookie
JWT_EXPIRES_IN=7d

# Where user vaults and the sqlite database file are stored.
# In Docker this is mounted as a volume so it can be backed up.
DATA_ROOT=./data

# Set to "false" to disable self-service registration.
ALLOW_REGISTRATION=true

# Set to "true" only when serving over HTTPS so the auth cookie is marked Secure.
COOKIE_SECURE=false

# ---------------------------------------------------------------------------
# Storage quota
# ---------------------------------------------------------------------------
# Per-user storage limit in gigabytes. Default is 8 (free plan).
# Set to 0 for unlimited storage.
STORAGE_QUOTA_GB=8

# ---------------------------------------------------------------------------
# Encryption at rest (default: enabled)
# ---------------------------------------------------------------------------
# Encrypts vault contents (notes, drawings, attachments, PDFs) with AES-256-GCM
# in Node.js before they are written to disk or object storage. Exports are
# always decrypted so you keep a portable backup.
ENCRYPTION_ENABLED=true
# The master key used for at-rest encryption. Generate a strong value, e.g.
# `openssl rand -hex 32`. IMPORTANT: keep this stable and back it up — if it
# changes, previously stored data can no longer be decrypted.
# If left empty, the key is derived from JWT_SECRET (setting a dedicated key
# is strongly recommended).
ENCRYPTION_KEY=

# ---------------------------------------------------------------------------
# Database (default: sqlite)
# ---------------------------------------------------------------------------
# DB_TYPE: "sqlite" (default, stored at DATA_ROOT/app.db) or "postgres".
DB_TYPE=sqlite
# The following are only used when DB_TYPE=postgres:
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=
DB_DATABASE=web_obsidian
# Set DB_SSL=true to connect to managed Postgres over TLS.
DB_SSL=false

# ---------------------------------------------------------------------------
# Vault storage backend (default: local server filesystem)
# ---------------------------------------------------------------------------
# STORAGE_DRIVER: "local" (default, stores files under DATA_ROOT) or "s3".
# NOTE: the "s3" driver is a stub and not yet implemented.
STORAGE_DRIVER=local
# The following are only used when STORAGE_DRIVER=s3 (S3-compatible: AWS S3,
# MinIO, Mega S3, Azure Blob via S3 gateway, etc.):
S3_ENDPOINT=
S3_REGION=us-east-1
S3_BUCKET=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
# Path-style addressing is required by MinIO and some S3-compatibles.
S3_FORCE_PATH_STYLE=true
# Optional key prefix so multiple apps can share one bucket.
S3_PREFIX=
