# Server
PORT=3065

# Comma separated list is not needed; single secret used to sign JWTs.
# Generate a strong random value, e.g. `openssl rand -hex 32`
JWT_SECRET=change-me-please-use-a-long-random-string

# JWT lifetime for the authenticated session cookie
JWT_EXPIRES_IN=7d

# Where user vaults and the sqlite database file are stored.
# In Docker this is mounted as a volume so it can be backed up.
DATA_ROOT=./data

# Set to "false" to disable self-service registration.
ALLOW_REGISTRATION=true

# Maximum number of registered users. Leave unset (or set to 0) for unlimited.
# Raise this value as you scale out to more server capacity. When the cap is
# reached, new sign-ups are rejected and the landing / registration pages show
# how many spots remain so visitors always know the current status.
# Example: MAX_REGISTRATIONS=100
MAX_REGISTRATIONS=

# Set to "true" only when serving over HTTPS so the auth cookie is marked Secure.
# NOTE: the browser-side end-to-end encryption uses the Web Crypto API, which is
# only available in a "secure context" — i.e. HTTPS, or http://localhost. When
# testing from another device (e.g. a phone on your LAN over plain http://IP),
# crypto.subtle is unavailable and the vault cannot be unlocked. Serve over
# HTTPS (a tunnel such as Cloudflare Tunnel/ngrok works) to test off-localhost.
COOKIE_SECURE=false

# Comma-separated list of origins allowed to call the backend from a browser
# (CORS). Use your public site origin(s) in production, e.g.
# https://app.example.com,https://example.com
# If left empty it defaults to APP_URL, so only this domain is allowed.
CORS_ORIGINS=http://localhost:3065

# ---------------------------------------------------------------------------
# Storage quota
# ---------------------------------------------------------------------------
# Storage allowance in gigabytes. Set to 0 for unlimited.
# Fractional values are allowed for sub-GB quotas: 0.5 = 512 MB, 0.8 ≈ 819 MB.
# - When billing is OFF (see BILLING_ENABLED below): this is the vault size
#   every account gets (i.e. the free == maximum vault size).
# - When billing is ON: the free tier is a fixed 1 GB and this value is
#   ignored (paid tiers are 5 GB and 20 GB).
STORAGE_QUOTA_GB=0.5

# ---------------------------------------------------------------------------
# Maximum upload / request body size
# ---------------------------------------------------------------------------
# Largest accepted request body in megabytes. Vault content is uploaded as a
# base64 JSON payload, so this effectively caps a single file/note upload.
# Applies to both JSON and urlencoded bodies. Default: 25.
MAX_UPLOAD_SIZE_MB=25

# ---------------------------------------------------------------------------
# Trash / soft-delete (default: 7 days)
# ---------------------------------------------------------------------------
# When a file or folder is deleted it is moved to a hidden per-user trash
# instead of being erased, so it can be recovered. A daily job permanently
# removes items that have been in the trash longer than this many days.
# Trashed items are hidden from the file tree but still count toward the
# storage quota until they are purged. Set to 0 to disable soft-delete
# (deletions are immediate).
TRASH_RETENTION_DAYS=7

# ---------------------------------------------------------------------------
# API rate limiting (protects the storage backend / caps S3 request costs)
# ---------------------------------------------------------------------------
# Throttles requests to the data API (/api/*) per user (per IP for anonymous
# callers). This stops a single account from hammering storage — e.g. by
# reloading the page in a loop — which directly caps S3/Mega S3 request costs
# and blunts trivial DDoS attempts. When the limit is hit the API returns HTTP
# 429 and the UI shows a clear toast.
#
# Set RATE_LIMIT_ENABLED=false to turn it off entirely.
RATE_LIMIT_ENABLED=true
# Length of the rolling window in seconds (60 = "per minute").
RATE_LIMIT_WINDOW_SECONDS=60
# Maximum number of API requests allowed per window, per user/IP. NOTE: one
# page load fires several API calls (file tree + opened note, etc.), so keep
# this comfortably above the number of "reloads per minute" you want to allow.
# One note on tuning: a single page reload fires several API calls (file tree + the opened note, etc.), so RATE_LIMIT_MAX should be set comfortably above the raw number of reloads-per-minute you want to permit — e.g. for ~5 reloads/min you'd want a max of roughly 15–25, not 5. I documented this in both the README and
# 3 reloads × ~2 calls/reload = 6. The window of 60s = "per minute", and MAX=6 gives 3 full reloads.
RATE_LIMIT_MAX=6

# Search file-list cache (milliseconds). Name search enumerates the whole vault
# once and caches that flat list per user for this long, so a burst of searches
# reuses it instead of re-listing storage (cheap S3 cost, fast results). New or
# renamed files may take up to this long to appear in name search. Set to 0 to
# disable the cache. Default 15000 (15s).
SEARCH_CACHE_TTL_MS=15000

# ---------------------------------------------------------------------------
# Encryption
# ---------------------------------------------------------------------------
# Vault CONTENTS (notes, drawings, attachments) are end-to-end encrypted in the
# user's BROWSER with AES-256-GCM before upload — the server only ever stores
# ciphertext it cannot read. That client-side encryption is always on and needs
# no server key.
#
# The settings below are a SEPARATE, server-side layer that only encrypts a few
# sensitive DATABASE COLUMNS at rest (TOTP secrets, Stripe IDs). They do NOT
# touch vault files.
ENCRYPTION_ENABLED=true
# Master key for the database-column encryption above. Generate a strong value,
# e.g. `openssl rand -hex 32`. IMPORTANT: keep this stable and back it up — if
# it changes, those encrypted columns can no longer be decrypted.
# If left empty, the key is derived from JWT_SECRET (setting a dedicated key is
# strongly recommended).
ENCRYPTION_KEY=

# ---------------------------------------------------------------------------
# Database (default: sqlite)
# ---------------------------------------------------------------------------
# DB_TYPE: "sqlite" (default, stored at DATA_ROOT/app.db) or "postgres".
DB_TYPE=sqlite
# The following are only used when DB_TYPE=postgres:
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=
DB_DATABASE=web_obsidian
# Set DB_SSL=true to connect to managed Postgres over TLS.
DB_SSL=false

# ---------------------------------------------------------------------------
# Vault storage backend (default: local server filesystem)
# ---------------------------------------------------------------------------
# STORAGE_DRIVER: "local" (default, stores files under DATA_ROOT) or "s3".
# The following are only used when STORAGE_DRIVER=s3 (S3-compatible: MEGA S4,
# AWS S3, MinIO, etc.). For MEGA S4, set S3_ENDPOINT to your S4 endpoint and
# S3_REGION to its region (e.g. https://s3.eu-central-2.s4.mega.io / eu-central-2).
STORAGE_DRIVER=s3    #local
S3_ENDPOINT=https://s3.<region>.s4.mega.io
S3_REGION=<region>
S3_BUCKET=<your-bucket>
S3_ACCESS_KEY_ID=<key>
S3_SECRET_ACCESS_KEY=<secret>
S3_FORCE_PATH_STYLE=true

# ---------------------------------------------------------------------------
# Billing / subscriptions (Stripe) — optional
# ---------------------------------------------------------------------------
# Storage tiers: free = 1 GB, plus5 = 5 GB (3,50 €/mo billed 42 €/yr),
# plus20 = 20 GB (6 €/mo billed 72 €/yr). Subscriptions are recurring annual.
#
# BILLING_ENABLED switches the whole payment feature on/off.
# - false (self-hosting): every account gets STORAGE_QUOTA_GB and no plans,
#   upgrades, subscriptions or account blacklisting apply.
# - true: the free tier becomes a fixed 1 GB and the dashboard shows the plan
#   section with upgrade buttons. Set the Stripe keys below for checkout to
#   actually work; until they are set the buttons are shown but disabled and
#   no account is ever blacklisted.
# If unset, billing defaults to on only when STRIPE_SECRET_KEY is present.
# Use Stripe test-mode keys here while developing.
#
# No webhooks are required: the app pulls the subscription state from Stripe
# right after checkout and during the nightly reconcile job. You only need the
# secret key and the two price IDs below.
BILLING_ENABLED=false
STRIPE_SECRET_KEY=
# Recurring (yearly) Price ID for the single paid plan, created in the Stripe
# dashboard. (STRIPE_PRICE_5GB is still read as a fallback for old setups.)
STRIPE_PRICE_PLUS=  # priceID like price_1TifYefefefeokhXGwi45
# Public base URL used to build Stripe success/cancel redirect URLs.
APP_URL=http://localhost:3065

# ---------------------------------------------------------------------------
# Paid plan (single tier) — voluntary donation, non-profit
# ---------------------------------------------------------------------------
# There is one paid plan on top of the free allowance. Its size and suggested
# donation are configurable. The contribution is a voluntary donation toward
# storage/server costs — websidian is non-profit, this is not a commercial sale.
#
# Storage size of the paid plan, in whole GB (default 3).
STORAGE_PLUS_GB=3
# Human-readable suggested donation shown on the landing page (display only,
# does not affect Stripe). Example: "€10 / year". (PRICE_5GB read as fallback.)
PRICE_PLUS=
# Contact address shown for custom / larger storage requests.
CONTACT_EMAIL=

# Privileged users — free dedicated storage, no payment.
# Comma-separated usernames (case-insensitive), e.g. userA,userB. These accounts
# automatically get STORAGE_PRIVILEGED_USERS_GB of storage for free, are excluded
# from billing, and never see the upgrade button. Independent of STORAGE_QUOTA_GB
# and STORAGE_PLUS_GB. Unioned with the privileged_users DB table.
PRIVILEGED_USERS=
# Storage allowance for privileged users, in whole GB (default 20). Applies
# regardless of the free/paid tier sizes.
STORAGE_PRIVILEGED_USERS_GB=20

# ---------------------------------------------------------------------------
# Legal pages
# ---------------------------------------------------------------------------
# Legal pages are opt-in: each is hidden by default. Set a flag to "true" to
# show that page; when disabled the route redirects home and the footer link is
# hidden. Useful when self-hosting outside a jurisdiction where these apply.
#   AGB           -> AGB (German terms & conditions) page
#   IMPRINT       -> Imprint page
#   LEGAL_NOTICE  -> Privacy policy page
AGB=
IMPRINT=
LEGAL_NOTICE=


# Self-hoster
CLOUDFLARE_TOKEN=

# Maximum size of a single uploaded file in megabytes. Folder uploads go through
# the resumable tus endpoint (/files) in 50 MB chunks; this is the per-file
# ceiling the tus server enforces (it rejects an over-size upload at creation).
# Default: 2048 (2 GB).
MAX_UPLOAD_FILE_MB=2048

# Soft, client-side hint for how many files one folder import should contain. The
# authoritative total limit is the storage quota (STORAGE_QUOTA_GB), enforced
# server-side per file as each chunked upload completes. Default: 20000.
MAX_IMPORT_FILES=20000

# Soft, client-side hint for the total size of one folder import. The real cap on
# how much a user can store is STORAGE_QUOTA_GB, checked server-side as each file
# lands. Default: 2048 (2 GB).
MAX_IMPORT_TOTAL_MB=2048

# How long (minutes) the server keeps a single request open. With chunked tus
# uploads each request is just one 50 MB chunk (short), but the single-file
# /api/upload path and slow links still benefit from a generous window. Node's
# default is 5 min. Default: 30.
UPLOAD_REQUEST_TIMEOUT_MIN=30

# Scratch directory where the tus server assembles incomplete chunked uploads
# before they are streamed into the vault on completion. Must be writable and
# have room for the largest in-flight upload. Default: <os-tmp>/websidian-tus.
TUS_TMP_DIR=./websidian-tus