<!DOCTYPE html>
<html lang="en">
<head>
  <%- include('partials/head', { title: 'web-obsidian' }) %>
  <link rel="stylesheet" href="/public/js/excalidraw-bundle.css" />
</head>
<body class="app" data-username="<%= username %>">
  <header class="topbar">
    <button id="sidebar-toggle" class="icon-btn" aria-label="Toggle sidebar"><i class="bi bi-list"></i></button>
    <span class="brand"><i class="bi bi-journal-text"></i> web-obsidian</span>
    <div class="search-wrap">
      <i class="bi bi-search search-icon"></i>
      <input id="search-input" type="search" placeholder="Search notes…" autocomplete="off" />
      <div id="search-results" class="search-results" hidden></div>
    </div>
    <div class="topbar-right">
      <button id="theme-toggle" class="icon-btn" title="Toggle light/dark"><i class="bi bi-circle-half"></i></button>
      <button id="account-btn" class="user" title="Account & storage"><i class="bi bi-person-circle"></i> <span class="user-name"><%= username %></span></button>
      <button id="logout-btn" class="btn-ghost"><i class="bi bi-box-arrow-right"></i> Logout</button>
    </div>
  </header>

  <div class="layout">
    <aside class="sidebar" id="sidebar">
      <div class="sidebar-tools">
        <button id="new-note" title="New note"><i class="bi bi-file-earmark-plus"></i> Note</button>
        <button id="new-file" title="New file (any type, e.g. .excalidraw)"><i class="bi bi-file-earmark-plus-fill"></i> File</button>
        <button id="new-folder" title="New folder"><i class="bi bi-folder-plus"></i> Folder</button>
        <button id="upload-btn" title="Upload a file"><i class="bi bi-upload"></i> Upload</button>
        <button id="import-btn" title="Import a folder or .zip"><i class="bi bi-folder-symlink"></i> Import</button>
        <button id="export-btn" title="Download the whole vault as a .zip"><i class="bi bi-download"></i> Export</button>
      </div>
      <div id="selected-folder" class="selected-folder breadcrumb" aria-label="Selected folder"></div>
      <nav id="tree" class="tree" aria-label="Files"></nav>
    </aside>

    <div class="sidebar-backdrop" id="sidebar-backdrop" hidden></div>

    <main class="content" id="content">
      <div class="welcome" id="welcome">
        <h2><i class="bi bi-journal-richtext"></i> Welcome</h2>
        <p>Select a note from the sidebar, or create a new one.</p>
      </div>

      <section id="editor-view" class="view" hidden>
        <div class="view-header">
          <span id="current-path" class="current-path breadcrumb"></span>
          <div class="view-actions">
            <button id="toggle-preview" class="btn-ghost" title="Switch between editing and reading">
              <i class="bi bi-eye"></i> <span class="btn-label">View</span>
            </button>
            <button id="save-btn" class="btn-primary"><i class="bi bi-save"></i> Save</button>
          </div>
        </div>
        <div class="editor-body" id="editor-body">
          <textarea id="editor" spellcheck="false" placeholder="# Start writing…"></textarea>
          <div id="preview" class="preview markdown" hidden></div>
        </div>
      </section>

      <section id="viewer-view" class="view" hidden>
        <div class="view-header">
          <span id="viewer-path" class="current-path breadcrumb"></span>
          <div class="view-actions">
            <a id="viewer-download" class="btn-ghost" download><i class="bi bi-download"></i> Download</a>
          </div>
        </div>
        <div id="viewer-body" class="viewer-body"></div>
      </section>

      <section id="excalidraw-view" class="view" hidden>
        <div class="view-header">
          <span id="excalidraw-path" class="current-path breadcrumb"></span>
          <div class="view-actions">
            <button id="excalidraw-save" class="btn-primary"><i class="bi bi-save"></i> Save</button>
          </div>
        </div>
        <div id="excalidraw-root" class="excalidraw-root"></div>
      </section>
    </main>
  </div>

  <div id="context-menu" class="context-menu" hidden>
    <button data-action="rename"><i class="bi bi-pencil"></i> Rename</button>
    <button data-action="new-note" data-folder-only><i class="bi bi-file-earmark-plus"></i> New note</button>
    <button data-action="new-file" data-folder-only><i class="bi bi-file-earmark-plus-fill"></i> New file</button>
    <button data-action="new-folder" data-folder-only><i class="bi bi-folder-plus"></i> New folder</button>
    <div class="context-menu-sep" data-folder-only></div>
    <button data-action="delete"><i class="bi bi-trash"></i> Delete</button>
  </div>

  <div id="modal-overlay" class="modal-overlay" hidden>
    <div class="modal" role="dialog" aria-modal="true" aria-labelledby="modal-title">
      <h3 id="modal-title" class="modal-title"></h3>
      <p id="modal-message" class="modal-message" hidden></p>
      <input id="modal-input" class="modal-input" type="text" hidden autocomplete="off" />
      <div class="modal-actions">
        <button id="modal-cancel" class="btn-ghost" type="button"></button>
        <button id="modal-ok" class="btn-primary" type="button"></button>
      </div>
    </div>
  </div>

  <div id="dashboard-overlay" class="modal-overlay" hidden>
    <div class="modal dashboard" role="dialog" aria-modal="true" aria-labelledby="dashboard-title">
      <div class="dashboard-head">
        <h3 id="dashboard-title" class="modal-title"><i class="bi bi-person-circle"></i> Account</h3>
        <button id="dashboard-close" class="icon-btn" title="Close" aria-label="Close"><i class="bi bi-x-lg"></i></button>
      </div>

      <div class="dashboard-section">
        <div class="dashboard-row">
          <span class="dashboard-label">Signed in as</span>
          <span id="dashboard-username" class="dashboard-value"></span>
        </div>
      </div>

      <div class="dashboard-section">
        <h4 class="dashboard-subtitle"><i class="bi bi-hdd"></i> Storage</h4>
        <div class="usage-bar"><div id="usage-fill" class="usage-fill"></div></div>
        <div class="usage-text"><span id="usage-text">Loading…</span></div>
        <p class="dashboard-hint">Free plan. Upgrades for more storage are coming soon.</p>
      </div>

      <div class="dashboard-section danger-zone">
        <h4 class="dashboard-subtitle"><i class="bi bi-exclamation-triangle"></i> Danger zone</h4>
        <p class="dashboard-hint">Deleting your account permanently removes all your notes, files and account data. This cannot be undone.</p>
        <button id="delete-account-btn" class="btn-danger"><i class="bi bi-trash"></i> Delete account</button>
      </div>
    </div>
  </div>

  <input id="upload-input" type="file" hidden multiple />
  <input id="import-input" type="file" hidden multiple />

  <script src="/public/js/app.js"></script>
</body>
</html>
