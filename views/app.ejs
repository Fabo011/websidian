<!DOCTYPE html>
<html lang="en">
<head>
  <%- include('partials/head', { title: 'websidian' }) %>
  <link rel="stylesheet" href="/public/js/excalidraw-bundle.css?v=<%= v %>" />
</head>
<body class="app" data-username="<%= username %>"
      data-user-storage="<%= typeof userStorageEnabled !== 'undefined' && userStorageEnabled ? '1' : '' %>"
      data-storage-configured="<%= typeof storageConfigured !== 'undefined' && storageConfigured ? '1' : '' %>"
      data-contact="<%= typeof contactEmail !== 'undefined' ? contactEmail : '' %>">
  <header class="topbar">
    <button id="sidebar-toggle" class="icon-btn" aria-label="Toggle sidebar" data-i18n-attr="aria-label:toggle_sidebar"><i class="bi bi-list"></i></button>
    <span class="brand"><i class="bi bi-journal-text"></i> websidian</span>
    <button id="search-open-btn" class="icon-btn search-open-btn" type="button" title="Search" aria-label="Search" data-i18n-attr="title:search_button;aria-label:search_button"><i class="bi bi-search"></i></button>
    <div class="topbar-right">
      <button id="account-btn" class="user" title="Settings" data-i18n-attr="title:open_settings"><i class="bi bi-person-circle"></i> <span class="user-name"><%= username %></span></button>
      <button id="logout-btn" class="btn-ghost"><i class="bi bi-box-arrow-right"></i> <span class="btn-label" data-i18n="logout">Logout</span></button>
    </div>
  </header>

  <div class="layout">
    <aside class="sidebar" id="sidebar">
      <div class="sidebar-tools">
        <button id="new-note" title="Create a new markdown note" data-i18n-attr="title:title_new_note"><i class="bi bi-file-earmark-plus"></i> <span data-i18n="tool_note">Note</span></button>
        <button id="new-file" title="Create a new Excalidraw drawing" data-i18n-attr="title:title_new_file"><i class="bi bi-pencil-square"></i> <span data-i18n="tool_file">Drawing</span></button>
        <button id="new-folder" title="Create a new folder" data-i18n-attr="title:title_new_folder"><i class="bi bi-folder-plus"></i> <span data-i18n="tool_folder">Folder</span></button>
        <button id="weblinks-btn" title="Open the web link manager" data-i18n-attr="title:title_weblinks"><i class="bi bi-link-45deg"></i> <span data-i18n="tool_weblinks">Web links</span></button>
        <button id="graph-btn" title="Open the wikilink graph" data-i18n-attr="title:title_graph"><i class="bi bi-diagram-3"></i> <span data-i18n="tool_graph">Graph</span></button>
        <button id="upload-btn" title="Upload files from your computer" data-i18n-attr="title:title_upload"><i class="bi bi-file-earmark-arrow-up"></i> <span data-i18n="tool_upload">Upload files</span></button>
        <button id="import-btn" title="Import folders or a whole vault (.zip)" data-i18n-attr="title:title_import"><i class="bi bi-folder-symlink"></i> <span data-i18n="tool_import">Import folder</span></button>
        <button id="export-btn" title="Download the whole vault as a .zip" data-i18n-attr="title:title_export"><i class="bi bi-download"></i> <span data-i18n="tool_export">Export</span></button>
        <button id="trash-btn" title="Open the trash to restore or permanently delete items" data-i18n-attr="title:title_trash"><i class="bi bi-trash3"></i> <span data-i18n="tool_trash">Trash</span></button>
      </div>
      <div id="selected-folder" class="selected-folder breadcrumb" aria-label="Selected folder" data-i18n-attr="aria-label:selected_folder"></div>
      <nav id="tree" class="tree" aria-label="Files" data-i18n-attr="aria-label:files_aria"></nav>
    </aside>

    <div class="sidebar-resizer" id="sidebar-resizer" role="separator" aria-orientation="vertical" aria-label="Resize sidebar" data-i18n-attr="aria-label:resize_sidebar"></div>

    <div class="sidebar-backdrop" id="sidebar-backdrop" hidden></div>

    <main class="content" id="content">
      <div id="tabbar" class="tabbar" role="tablist" aria-label="Open files" data-i18n-attr="aria-label:tabs_aria" hidden></div>

      <div class="welcome" id="welcome">
        <h2><i class="bi bi-journal-richtext"></i> <span data-i18n="welcome">Welcome</span></h2>
        <p data-i18n="welcome_text">Select a note from the sidebar, or create a new one.</p>
      </div>

      <section id="editor-view" class="view" hidden>
        <div class="view-header">
          <button class="icon-btn mobile-back" data-mobile-back title="Show files" aria-label="Show files" data-i18n-attr="title:open_files_title;aria-label:open_files"><i class="bi bi-list"></i></button>
          <span id="current-path" class="current-path breadcrumb"></span>
          <div class="view-actions">
            <button id="toggle-preview" class="btn-ghost" title="Switch between editing and reading" data-i18n-attr="title:title_toggle_view">
              <i class="bi bi-eye"></i> <span class="btn-label">View</span>
            </button>
            <button id="save-btn" class="btn-primary"><i class="bi bi-save"></i> <span class="btn-label" data-i18n="save">Save</span></button>
          </div>
        </div>
        <div class="editor-body" id="editor-body">
          <div id="editor-toolbar" class="editor-toolbar" hidden role="toolbar" aria-label="Markdown formatting">
            <button type="button" class="md-btn" data-md="bold" title="Bold — wrap text in ** ** · e.g. **important**" data-i18n-attr="title:md_bold_tip;aria-label:md_bold_tip" aria-label="Bold">
              <i class="bi bi-type-bold"></i>
            </button>
            <button type="button" class="md-btn" data-md="highlight" title="Highlight — wrap text in == == · e.g. ==important==" data-i18n-attr="title:md_highlight_tip;aria-label:md_highlight_tip" aria-label="Highlight">
              <i class="bi bi-highlighter"></i>
            </button>
            <div class="md-dropdown">
              <button type="button" class="md-btn" data-md-heading-toggle aria-haspopup="true" aria-expanded="false" title="Heading — pick a level (#, ##, …) · e.g. # Title" data-i18n-attr="title:md_heading_tip;aria-label:md_heading_tip" aria-label="Heading">
                <i class="bi bi-type-h1"></i> <i class="bi bi-caret-down-fill md-caret"></i>
              </button>
              <div id="md-heading-menu" class="md-menu" hidden>
                <button type="button" class="md-menu-item" data-md="h1"><span><i class="bi bi-type-h1"></i> Heading 1</span><span class="md-sample">#</span></button>
                <button type="button" class="md-menu-item" data-md="h2"><span><i class="bi bi-type-h2"></i> Heading 2</span><span class="md-sample">##</span></button>
                <button type="button" class="md-menu-item" data-md="h3"><span><i class="bi bi-type-h3"></i> Heading 3</span><span class="md-sample">###</span></button>
                <button type="button" class="md-menu-item" data-md="h4"><span><i class="bi bi-type-h4"></i> Heading 4</span><span class="md-sample">####</span></button>
                <button type="button" class="md-menu-item" data-md="h5"><span><i class="bi bi-type-h5"></i> Heading 5</span><span class="md-sample">#####</span></button>
                <button type="button" class="md-menu-item" data-md="h6"><span><i class="bi bi-type-h6"></i> Heading 6</span><span class="md-sample">######</span></button>
              </div>
            </div>
            <button type="button" class="md-btn" data-md="list" title="Bullet list — start a line with &quot;- &quot; · e.g. - item" data-i18n-attr="title:md_list_tip;aria-label:md_list_tip" aria-label="Bullet list">
              <i class="bi bi-list-ul"></i>
            </button>
            <button type="button" class="md-btn" data-md="checklist" title="Task list — start a line with &quot;- [ ] &quot; · e.g. - [ ] to do" data-i18n-attr="title:md_check_tip;aria-label:md_check_tip" aria-label="Task list">
              <i class="bi bi-check2-square"></i>
            </button>
            <button type="button" class="md-btn" data-md="image" title="Embed image — ![[file]] · e.g. ![[diagram.png]]" data-i18n-attr="title:md_image_tip;aria-label:md_image_tip" aria-label="Embed image">
              <i class="bi bi-image"></i>
            </button>
            <button type="button" class="md-btn" data-md="wikilink" title="Internal link — [[Note]] · e.g. [[The System]]" data-i18n-attr="title:md_wikilink_tip;aria-label:md_wikilink_tip" aria-label="Internal link">
              <i class="bi bi-link-45deg"></i>
            </button>
          </div>
          <div class="editor-surface">
            <textarea id="editor" spellcheck="false" placeholder="# Start writing…"></textarea>
            <div id="preview" class="preview markdown" hidden></div>
            <div id="wikilink-suggest" class="wikilink-suggest" hidden role="listbox" aria-label="Link suggestions"></div>
          </div>
        </div>
      </section>

      <section id="viewer-view" class="view" hidden>
        <div class="view-header">
          <button class="icon-btn mobile-back" data-mobile-back title="Show files" aria-label="Show files" data-i18n-attr="title:open_files_title;aria-label:open_files"><i class="bi bi-list"></i></button>
          <span id="viewer-path" class="current-path breadcrumb"></span>
          <div class="view-actions">
            <a id="viewer-download" class="btn-ghost" download><i class="bi bi-download"></i> <span class="btn-label" data-i18n="download">Download</span></a>
          </div>
        </div>
        <div id="viewer-body" class="viewer-body"></div>
      </section>

      <section id="excalidraw-view" class="view" hidden>
        <div class="view-header">
          <button class="icon-btn mobile-back" data-mobile-back title="Show files" aria-label="Show files" data-i18n-attr="title:open_files_title;aria-label:open_files"><i class="bi bi-list"></i></button>
          <span id="excalidraw-path" class="current-path breadcrumb"></span>
          <div class="view-actions">
            <button id="excalidraw-save" class="btn-primary"><i class="bi bi-save"></i> <span class="btn-label" data-i18n="save">Save</span></button>
          </div>
        </div>
        <div id="excalidraw-root" class="excalidraw-root"></div>
      </section>

      <section id="weblinks-view" class="view" hidden>
        <div class="view-header">
          <button class="icon-btn mobile-back" data-mobile-back title="Show files" aria-label="Show files" data-i18n-attr="title:open_files_title;aria-label:open_files"><i class="bi bi-list"></i></button>
          <span class="current-path breadcrumb"><i class="bi bi-link-45deg"></i> <span data-i18n="weblinks_title">Web links</span> <span class="weblinks-path">weblinks/weblinks.csv</span></span>
          <div class="view-actions">
            <span id="weblinks-count" class="weblinks-count"></span>
          </div>
        </div>
        <div class="weblinks-toolbar" role="toolbar" aria-label="Web links actions">
          <button type="button" id="weblink-add" class="md-btn" title="Add a new web link" data-i18n-attr="title:weblinks_add_tip">
            <i class="bi bi-plus-lg"></i> <span data-i18n="weblinks_add">Add link</span>
          </button>
          <button type="button" id="weblink-import" class="md-btn" title="Import links from a CSV file (Linky format supported)" data-i18n-attr="title:weblinks_import_tip">
            <i class="bi bi-filetype-csv"></i> <span data-i18n="weblinks_import">Import CSV</span>
          </button>
          <div class="weblinks-search-wrap">
            <i class="bi bi-search"></i>
            <input id="weblinks-search" type="search" autocomplete="off" placeholder="Search links…" data-i18n-attr="placeholder:weblinks_search" />
          </div>
        </div>
        <div class="weblinks-body">
          <p class="weblinks-intro" data-i18n="weblinks_intro">Save links once, then always reach them from your vault. Useful so you never forget a link again — and safer too: evaluate a link a single time, store it, and you always open exactly that link instead of a manipulated one.</p>
          <div id="weblinks-list" class="weblinks-list"></div>
          <div id="weblinks-empty" class="weblinks-empty" hidden>
            <i class="bi bi-link-45deg"></i>
            <p data-i18n="weblinks_none">No web links yet. Add one or import a CSV.</p>
          </div>
        </div>
      </section>

      <section id="graph-view" class="view graph-view" hidden>
        <div class="view-header">
          <button class="icon-btn mobile-back" data-mobile-back title="Show files" aria-label="Show files" data-i18n-attr="title:open_files_title;aria-label:open_files"><i class="bi bi-list"></i></button>
          <span class="current-path breadcrumb"><i class="bi bi-diagram-3"></i> <span data-i18n="graph_title">Graph</span></span>
          <div class="view-actions">
            <button id="graph-zoom-out" class="icon-btn" type="button" title="Zoom out" aria-label="Zoom out" data-i18n-attr="title:graph_zoom_out;aria-label:graph_zoom_out"><i class="bi bi-dash-lg"></i></button>
            <button id="graph-zoom-in" class="icon-btn" type="button" title="Zoom in" aria-label="Zoom in" data-i18n-attr="title:graph_zoom_in;aria-label:graph_zoom_in"><i class="bi bi-plus-lg"></i></button>
            <button id="graph-refresh" class="icon-btn" type="button" title="Rebuild the graph" aria-label="Rebuild the graph" data-i18n-attr="title:graph_refresh;aria-label:graph_refresh"><i class="bi bi-arrow-clockwise"></i></button>
          </div>
        </div>
        <div class="graph-body" id="graph-body">
          <canvas id="graph-canvas"></canvas>
          <div id="graph-tooltip" class="graph-tooltip" hidden></div>
          <div id="graph-empty" class="graph-empty" hidden>
            <i class="bi bi-diagram-3"></i>
            <p data-i18n="graph_empty">No notes to graph yet. Create notes and connect them with [[wikilinks]].</p>
          </div>
          <div id="graph-hint" class="graph-hint" data-i18n="graph_hint">Tap a dot to see its name, then tap the name to open it.</div>
        </div>
      </section>
    </main>
  </div>

  <div id="context-menu-backdrop" class="context-menu-backdrop" hidden></div>
  <div id="context-menu" class="context-menu" hidden>
    <button data-action="rename"><i class="bi bi-pencil"></i> <span data-i18n="rename">Rename</span></button>
    <button data-action="new-note" data-folder-only><i class="bi bi-file-earmark-plus"></i> <span data-i18n="ctx_new_note">New note</span></button>
    <button data-action="new-file" data-folder-only><i class="bi bi-pencil-square"></i> <span data-i18n="ctx_new_file">New drawing</span></button>
    <button data-action="new-folder" data-folder-only><i class="bi bi-folder-plus"></i> <span data-i18n="ctx_new_folder">New folder</span></button>
    <button data-action="upload" data-folder-only><i class="bi bi-file-earmark-arrow-up"></i> <span data-i18n="ctx_upload">Upload files here</span></button>
    <button data-action="import" data-folder-only><i class="bi bi-folder-symlink"></i> <span data-i18n="ctx_import">Import folder here</span></button>
    <div class="context-menu-sep" data-folder-only></div>
    <button data-action="download"><i class="bi bi-download"></i> <span data-i18n="ctx_download">Download</span></button>
    <button data-action="delete"><i class="bi bi-trash"></i> <span data-i18n="delete">Delete</span></button>
  </div>

  <div id="search-overlay" class="modal-overlay search-overlay" hidden>
    <div class="search-panel" role="dialog" aria-modal="true" aria-label="Search" data-i18n-attr="aria-label:search_button">
      <div class="search-bar">
        <input id="search-input" type="search" placeholder="Search notes…" autocomplete="off" enterkeyhint="search" data-i18n-attr="placeholder:search_placeholder" />
        <button id="search-btn" class="search-btn" type="button" title="Search" aria-label="Search" data-i18n-attr="title:search_button;aria-label:search_button"><i class="bi bi-search"></i></button>
        <button id="search-close" class="icon-btn" type="button" title="Close" aria-label="Close" data-i18n-attr="title:close;aria-label:close"><i class="bi bi-x-lg"></i></button>
      </div>
      <div class="search-filters">
        <span class="search-filters-label" data-i18n="search_exclude_label">Exclude folders:</span>
        <div id="search-filters-chips" class="search-filters-chips"></div>
      </div>
      <div id="search-results" class="search-results"></div>
    </div>
  </div>

  <div id="modal-overlay" class="modal-overlay" hidden>
    <div class="modal" role="dialog" aria-modal="true" aria-labelledby="modal-title">
      <h3 id="modal-title" class="modal-title"></h3>
      <p id="modal-message" class="modal-message" hidden></p>
      <input id="modal-input" class="modal-input" type="text" hidden autocomplete="off" />
      <div class="modal-actions">
        <button id="modal-cancel" class="btn-ghost" type="button"></button>
        <button id="modal-ok" class="btn-primary" type="button"></button>
      </div>
    </div>
  </div>

  <div id="change-password-overlay" class="modal-overlay" hidden>
    <div class="modal" role="dialog" aria-modal="true" aria-labelledby="change-password-title">
      <div class="dashboard-head">
        <h3 id="change-password-title" class="modal-title"><i class="bi bi-key"></i> <span data-i18n="change_password">Change password</span></h3>
        <button id="change-password-close" class="icon-btn" title="Close" aria-label="Close" data-i18n-attr="title:close;aria-label:close"><i class="bi bi-x-lg"></i></button>
      </div>
      <p class="modal-message" data-i18n="change_password_hint">Changing your password requires your current password and a code from your authenticator app.</p>
      <form id="change-password-form" autocomplete="off">
        <label class="modal-label" for="cp-current" data-i18n="current_password">Current password</label>
        <input id="cp-current" class="modal-input" type="password" autocomplete="current-password" required />
        <label class="modal-label" for="cp-new" data-i18n="new_password">New password</label>
        <input id="cp-new" class="modal-input" type="password" autocomplete="new-password" minlength="8" required />
        <label class="modal-label" for="cp-confirm" data-i18n="confirm_new_password">Confirm new password</label>
        <input id="cp-confirm" class="modal-input" type="password" autocomplete="new-password" minlength="8" required />
        <label class="modal-label" for="cp-code" data-i18n="totp_code">Authenticator code</label>
        <input id="cp-code" class="modal-input" type="text" inputmode="numeric" pattern="\d{6}" maxlength="6" autocomplete="one-time-code" required />
        <p id="cp-error" class="modal-error" hidden></p>
        <div class="modal-actions">
          <button id="cp-cancel" class="btn-ghost" type="button" data-i18n="cancel">Cancel</button>
          <button id="cp-submit" class="btn-primary" type="submit" data-i18n="change_password">Change password</button>
        </div>
      </form>
    </div>
  </div>

  <div id="reset-totp-overlay" class="modal-overlay" hidden>
    <div class="modal" role="dialog" aria-modal="true" aria-labelledby="reset-totp-title">
      <div class="dashboard-head">
        <h3 id="reset-totp-title" class="modal-title"><i class="bi bi-shield-lock"></i> <span data-i18n="reset_totp">Reset authenticator (2FA)</span></h3>
        <button id="reset-totp-close" class="icon-btn" title="Close" aria-label="Close" data-i18n-attr="title:close;aria-label:close"><i class="bi bi-x-lg"></i></button>
      </div>

      <form id="reset-totp-verify-form" autocomplete="off">
        <p class="modal-message" data-i18n="reset_totp_verify_hint">Confirm it's you with your current password and a code from your <strong>current</strong> authenticator.</p>
        <label class="modal-label" for="rt-current" data-i18n="current_password">Current password</label>
        <input id="rt-current" class="modal-input" type="password" autocomplete="current-password" required />
        <label class="modal-label" for="rt-current-code" data-i18n="rt_current_code">Current authenticator code</label>
        <input id="rt-current-code" class="modal-input" type="text" inputmode="numeric" pattern="\d{6}" maxlength="6" autocomplete="one-time-code" required />
        <p id="rt-verify-error" class="modal-error" hidden></p>
        <div class="modal-actions">
          <button id="rt-verify-cancel" class="btn-ghost" type="button" data-i18n="cancel">Cancel</button>
          <button id="rt-verify-submit" class="btn-primary" type="submit" data-i18n="continue">Continue</button>
        </div>
      </form>

      <form id="reset-totp-confirm-form" autocomplete="off" hidden>
        <p class="modal-message" data-i18n="reset_totp_scan_hint">Scan this QR code with your new authenticator app (or enter the secret manually), then enter a code from it to finish.</p>
        <img id="rt-qr" class="totp-qr" alt="TOTP QR code" />
        <div class="totp-secret">
          <span class="muted" data-i18n="secret">Secret</span>
          <code id="rt-secret"></code>
          <button type="button" id="rt-copy-secret" class="btn-ghost" data-i18n="copy">Copy</button>
        </div>
        <label class="modal-label" for="rt-new-code" data-i18n="rt_new_code">New authenticator code</label>
        <input id="rt-new-code" class="modal-input" type="text" inputmode="numeric" pattern="\d{6}" maxlength="6" autocomplete="one-time-code" required />
        <p id="rt-confirm-error" class="modal-error" hidden></p>
        <div class="modal-actions">
          <button id="rt-confirm-cancel" class="btn-ghost" type="button" data-i18n="cancel">Cancel</button>
          <button id="rt-confirm-submit" class="btn-primary" type="submit" data-i18n="confirm_finish">Confirm &amp; finish</button>
        </div>
      </form>
    </div>
  </div>

  <div id="dashboard-overlay" class="modal-overlay settings-overlay" hidden>
    <div class="settings-modal" role="dialog" aria-modal="true" aria-labelledby="dashboard-title">
      <aside class="settings-nav" id="settings-nav">
        <div class="settings-nav-head">
          <h3 id="dashboard-title" class="settings-title"><i class="bi bi-gear"></i> <span data-i18n="settings">Settings</span></h3>
          <button id="dashboard-close" class="icon-btn" title="Close" aria-label="Close" data-i18n-attr="title:close;aria-label:close"><i class="bi bi-x-lg"></i></button>
        </div>
        <div class="settings-search-wrap">
          <i class="bi bi-search"></i>
          <input id="settings-search" type="search" autocomplete="off" placeholder="Find a setting…" aria-label="Find a setting" data-i18n-attr="placeholder:settings_search;aria-label:settings_search" />
        </div>
        <nav class="settings-nav-list" role="tablist" aria-label="Settings sections">
          <button class="settings-nav-item active" type="button" data-pane="general" role="tab"><i class="bi bi-house-door"></i> <span data-i18n="nav_general">General</span></button>
          <button class="settings-nav-item" type="button" data-pane="storage" role="tab"><i class="bi bi-hdd"></i> <span data-i18n="nav_storage">File storage</span></button>
          <button class="settings-nav-item" type="button" data-pane="plan" role="tab" hidden><i class="bi bi-stars"></i> <span data-i18n="plan">Plan</span></button>
          <button class="settings-nav-item" type="button" data-pane="security" role="tab"><i class="bi bi-shield-lock"></i> <span data-i18n="security">Security</span></button>
          <button class="settings-nav-item" type="button" data-pane="account" role="tab"><i class="bi bi-person-gear"></i> <span data-i18n="nav_account">Account</span></button>
        </nav>
        <% if (typeof appVersion !== 'undefined' && appVersion) { %>
        <p class="settings-version" title="App version">websidian v<%= appVersion %></p>
        <% } %>
      </aside>

      <div class="settings-body" id="settings-body">
        <button id="settings-back" class="settings-back" type="button"><i class="bi bi-arrow-left"></i> <span data-i18n="nav_back">Settings</span></button>

        <!-- General -->
        <section class="settings-pane active" data-pane="general" role="tabpanel">
          <h2 class="settings-pane-title"><span data-i18n="nav_general">General</span></h2>

          <div class="settings-group">
            <div class="settings-row">
              <span class="settings-label" data-i18n="signed_in_as">Signed in as</span>
              <span id="dashboard-username" class="settings-value"></span>
            </div>
          </div>

          <% if (typeof donationLink !== 'undefined' && donationLink) { %>
          <div class="settings-group">
            <h3 class="settings-group-title"><i class="bi bi-heart"></i> <span data-i18n="support_title">Support websidian</span></h3>
            <p class="settings-hint" data-i18n="support_hint">websidian is a non-profit project. A voluntary donation helps cover storage &amp; server costs.</p>
            <a class="btn-ghost settings-inline-btn" href="<%= donationLink %>" target="_blank" rel="noopener"><i class="bi bi-heart"></i> <span data-i18n="donate">Donate</span></a>
          </div>
          <% } %>

          <div class="settings-group">
            <h3 class="settings-group-title"><i class="bi bi-journal-text"></i> <span data-i18n="help">Help</span></h3>
            <p class="settings-hint" data-i18n="docs_hint">Learn how syncing, backups, 2FA and encryption work.</p>
            <a class="btn-ghost settings-inline-btn" href="/docs" target="_blank" rel="noopener"><i class="bi bi-book"></i> <span data-i18n="open_docs">Open documentation</span></a>
          </div>

          <div class="settings-group">
            <h3 class="settings-group-title"><i class="bi bi-envelope"></i> <span data-i18n="contact_title">Contact &amp; support</span></h3>
            <p class="settings-hint" data-i18n="contact_hint">Questions, problems connecting your file storage, or a feature request? Get in touch.</p>
            <% if (typeof contactEmail !== 'undefined' && contactEmail) { %>
            <div class="settings-callout">
              <i class="bi bi-briefcase"></i>
              <span data-i18n="commercial_use_note">Commercial use requires a paid plan. For commercial licensing, get in touch:</span>
            </div>
            <div class="email-row">
              <a class="email-link" href="mailto:<%= contactEmail %>"><i class="bi bi-envelope"></i> <%= contactEmail %></a>
              <button type="button" class="email-copy" data-copy-email="<%= contactEmail %>" title="Copy email" aria-label="Copy email" data-i18n-attr="title:copy_email;aria-label:copy_email"><i class="bi bi-clipboard"></i></button>
            </div>
            <% } else { %>
            <p class="settings-hint" data-i18n="contact_none">No contact address is configured for this instance.</p>
            <% } %>
            <p class="settings-hint" data-i18n="discussions_hint">Join discussions and announcements — share feedback, feature ideas, and report bugs.</p>
            <a class="btn-ghost settings-inline-btn" href="https://github.com/Fabo011/websidian/discussions" target="_blank" rel="noopener noreferrer"><i class="bi bi-chat-dots"></i> <span data-i18n="open_discussions">GitHub Discussions</span></a>
          </div>
        </section>

        <!-- File storage -->
        <section class="settings-pane" data-pane="storage" role="tabpanel" hidden>
          <h2 class="settings-pane-title"><span data-i18n="nav_storage">File storage</span></h2>

          <% if (typeof userStorageEnabled !== 'undefined' && userStorageEnabled) { %>
          <div class="settings-group" id="storage-status-group">
            <h3 class="settings-group-title"><i class="bi bi-hdd-network"></i> <span data-i18n="storage_connection">Connection</span></h3>
            <div id="dash-storage-status" class="storage-status is-unknown">
              <span class="storage-status-dot"></span>
              <span class="storage-status-text"><span id="dash-storage-current" data-i18n="loading">Loading…</span></span>
            </div>
          </div>
          <% } %>

          <div class="settings-group">
            <h3 class="settings-group-title"><i class="bi bi-pie-chart"></i> <span data-i18n="storage_usage_title">Storage used</span></h3>
            <p class="settings-hint" data-i18n="storage_usage_hint">How much of your vault storage is currently in use.</p>
            <div class="usage-bar"><div id="usage-fill" class="usage-fill"></div></div>
            <div class="usage-text"><span id="usage-text" data-i18n="loading">Loading…</span></div>
          </div>

          <% if (typeof userStorageEnabled !== 'undefined' && userStorageEnabled) { %>
          <div class="settings-group" id="storage-provider-section">
            <h3 class="settings-group-title"><i class="bi bi-hdd-stack"></i> <span data-i18n="storage_provider">Storage provider</span></h3>
            <p class="settings-hint" data-i18n="storage_provider_hint">Connect or change the storage your encrypted vault is saved to. websidian never hosts your files.</p>
            <div class="settings-callout settings-callout-warn">
              <i class="bi bi-exclamation-triangle"></i>
              <span data-i18n="storage_no_migration">There is no automatic migration yet. If you switch storage, export your vault first and import it again into the new storage — otherwise your existing notes will not appear.</span>
            </div>
            <%- include('partials/storage-fields', { prefix: 'dash', contactEmail: contactEmail }) %>
            <p id="dash-storage-error" class="settings-hint form-error" hidden></p>
            <button id="dash-storage-save" class="btn-primary settings-inline-btn" type="button" data-i18n="storage_save">Save storage settings</button>
          </div>
          <% } %>

          <div class="settings-group">
            <h3 class="settings-group-title"><i class="bi bi-book"></i> <span data-i18n="storage_docs_title">Documentation</span></h3>
            <p class="settings-hint" data-i18n="storage_docs_hint">Step-by-step guides (with screenshots) for connecting Nextcloud (WebDAV) and Mega S4 (S3).</p>
            <a class="btn-ghost settings-inline-btn" href="/docs#connect-storage" target="_blank" rel="noopener"><i class="bi bi-book"></i> <span data-i18n="storage_help_link">How to connect (with screenshots)</span></a>
          </div>
        </section>

        <!-- Plan (billing) -->
        <section class="settings-pane" data-pane="plan" role="tabpanel" hidden>
          <h2 class="settings-pane-title"><span data-i18n="plan">Plan</span></h2>
          <div class="settings-group" id="plan-section">
            <div id="plan-warning" class="plan-warning" hidden></div>
            <div class="settings-row">
              <span class="settings-label" data-i18n="current_plan">Current plan</span>
              <span id="plan-value" class="settings-value">—</span>
            </div>
            <div id="plan-valid-row" class="settings-row" hidden>
              <span class="settings-label" data-i18n="plan_valid_until">Valid until</span>
              <span id="plan-valid" class="settings-value"></span>
            </div>
            <p id="plan-privileged-hint" class="settings-hint" data-i18n="plan_privileged_hint" hidden>You have complimentary top-tier access — no payment required.</p>
            <div id="plan-upgrade" class="plan-options" hidden>
              <button class="btn-primary plan-btn" type="button" data-plan="plus"><i class="bi bi-arrow-up-circle"></i> <span id="plan-upgrade-label" data-i18n="upgrade_plus">Get more storage</span></button>
            </div>
            <p id="plan-donation-note" class="settings-hint" data-i18n="plan_donation_note" hidden>A voluntary donation toward storage &amp; server costs — websidian is non-profit.</p>
            <a id="plan-donation-link" class="btn-ghost settings-inline-btn" target="_blank" rel="noopener" hidden><i class="bi bi-heart"></i> <span data-i18n="donate">Donate</span></a>
            <button id="manage-billing-btn" class="btn-ghost settings-inline-btn" type="button" hidden><i class="bi bi-credit-card"></i> <span data-i18n="manage_billing">Manage subscription</span></button>
            <p id="billing-unavailable" class="settings-hint" data-i18n="billing_unavailable" hidden>Paid upgrades are currently unavailable.</p>
            <div id="plan-commercial" class="settings-callout" hidden>
              <i class="bi bi-briefcase"></i>
              <span>
                <span data-i18n="commercial_use_note">Commercial use requires a paid plan. For commercial licensing, get in touch:</span>
                <span class="email-row email-row-inline">
                  <a id="plan-commercial-email" class="email-link" href="#"></a>
                  <button type="button" id="plan-commercial-copy" class="email-copy" data-copy-email="" title="Copy email" aria-label="Copy email" data-i18n-attr="title:copy_email;aria-label:copy_email"><i class="bi bi-clipboard"></i></button>
                </span>
              </span>
            </div>
          </div>
        </section>

        <!-- Security -->
        <section class="settings-pane" data-pane="security" role="tabpanel" hidden>
          <h2 class="settings-pane-title"><span data-i18n="security">Security</span></h2>
          <div class="settings-group">
            <h3 class="settings-group-title"><i class="bi bi-key"></i> <span data-i18n="change_password">Change password</span></h3>
            <p class="settings-hint" data-i18n="change_password_hint">Changing your password requires your current password and a code from your authenticator app.</p>
            <button id="change-password-btn" class="btn-ghost settings-inline-btn" type="button"><i class="bi bi-key"></i> <span data-i18n="change_password">Change password</span></button>
          </div>
          <div class="settings-group">
            <h3 class="settings-group-title"><i class="bi bi-shield-lock"></i> <span data-i18n="reset_totp">Reset authenticator (2FA)</span></h3>
            <p class="settings-hint" data-i18n="reset_totp_hint">Switching to a new phone or authenticator app? Reset your two-factor authentication to pair a new device.</p>
            <button id="reset-totp-btn" class="btn-ghost settings-inline-btn" type="button"><i class="bi bi-shield-lock"></i> <span data-i18n="reset_totp">Reset authenticator (2FA)</span></button>
          </div>
        </section>

        <!-- Account -->
        <section class="settings-pane" data-pane="account" role="tabpanel" hidden>
          <h2 class="settings-pane-title"><span data-i18n="nav_account">Account</span></h2>

          <div class="settings-group">
            <h3 class="settings-group-title"><i class="bi bi-circle-half"></i> <span data-i18n="appearance">Appearance</span></h3>
            <div class="settings-row">
              <span class="settings-label" data-i18n="theme">Theme</span>
              <div class="theme-switch" role="radiogroup" aria-label="Theme" data-i18n-attr="aria-label:theme">
                <button type="button" class="theme-opt" data-theme-set="light"><i class="bi bi-sun"></i> <span data-i18n="theme_light">Light</span></button>
                <button type="button" class="theme-opt" data-theme-set="dark"><i class="bi bi-moon-stars"></i> <span data-i18n="theme_dark">Dark</span></button>
              </div>
            </div>
          </div>

          <div class="settings-group">
            <h3 class="settings-group-title"><i class="bi bi-translate"></i> <span data-i18n="lang_switch">Language</span></h3>
            <div class="settings-row">
              <span class="settings-label" data-i18n="lang_switch">Language</span>
              <select id="lang-select" class="lang-select" data-lang-switch aria-label="Language" data-i18n-attr="aria-label:lang_switch">
                <option value="en">English</option>
                <option value="de">Deutsch</option>
              </select>
            </div>
          </div>

          <div class="settings-group danger-zone">
            <h3 class="settings-group-title"><i class="bi bi-exclamation-triangle"></i> <span data-i18n="danger_zone">Danger zone</span></h3>
            <p class="settings-hint" data-i18n="delete_account_hint">Deleting your account permanently removes all your notes, files and account data. This cannot be undone.</p>
            <button id="delete-account-btn" class="btn-danger"><i class="bi bi-trash"></i> <span data-i18n="delete_account">Delete account</span></button>
          </div>
        </section>

        <div class="settings-no-results" id="settings-no-results" hidden>
          <i class="bi bi-search"></i>
          <p data-i18n="settings_no_results">No settings match your search.</p>
        </div>
      </div>
    </div>
  </div>

  <div id="import-overlay" class="modal-overlay" hidden>
    <div class="modal" role="dialog" aria-modal="true" aria-labelledby="import-modal-title">
      <div class="dashboard-head">
        <h3 id="import-modal-title" class="modal-title"><i class="bi bi-folder-symlink"></i> <span data-i18n="import_title">Import folders</span></h3>
        <button id="import-modal-close" class="icon-btn" title="Close" aria-label="Close" data-i18n-attr="title:close;aria-label:close"><i class="bi bi-x-lg"></i></button>
      </div>
      <p class="modal-message" data-i18n="import_choose_hint">Import a whole vault to get started, or add more folders to an existing vault. The folder structure is preserved.</p>
      <div class="import-options">
        <button id="import-folder-choice" class="import-option" type="button">
          <i class="bi bi-folder2-open"></i>
          <span class="import-option-title" data-i18n="import_folder">Folder</span>
          <span class="import-option-desc" data-i18n="import_folder_desc">Pick a whole folder. It uploads in resumable chunks with the structure preserved — your browser will ask you to confirm.</span>
        </button>
      </div>
      <p class="muted import-limit-note" data-i18n="import_resume_note">Large uploads resume automatically if the connection drops or the page reloads.</p>
    </div>
  </div>

  <div id="trash-overlay" class="modal-overlay" hidden>
    <div class="modal" role="dialog" aria-modal="true" aria-labelledby="trash-modal-title">
      <div class="dashboard-head">
        <h3 id="trash-modal-title" class="modal-title"><i class="bi bi-trash3"></i> <span data-i18n="trash_title">Trash</span></h3>
        <button id="trash-modal-close" class="icon-btn" title="Close" aria-label="Close" data-i18n-attr="title:close;aria-label:close"><i class="bi bi-x-lg"></i></button>
      </div>
      <p class="modal-message" data-i18n="trash_hint">Deleted items are kept here so you can restore them. Emptying the trash deletes everything in it permanently.</p>
      <div id="trash-list" class="trash-list" aria-live="polite"></div>
      <div class="modal-actions">
        <button id="trash-empty-btn" class="btn-danger" type="button"><i class="bi bi-trash3"></i> <span data-i18n="trash_empty">Empty trash</span></button>
      </div>
    </div>
  </div>

  <input id="upload-input" type="file" hidden multiple />
  <input id="import-input" type="file" hidden multiple />
  <input id="weblinks-import-input" type="file" hidden accept=".csv,text/csv" />

  <div id="weblink-overlay" class="modal-overlay" hidden>
    <div class="modal" role="dialog" aria-modal="true" aria-labelledby="weblink-modal-title">
      <div class="dashboard-head">
        <h3 id="weblink-modal-title" class="modal-title"><i class="bi bi-link-45deg"></i> <span data-i18n="weblinks_add">Add link</span></h3>
        <button id="weblink-modal-close" class="icon-btn" title="Close" aria-label="Close" data-i18n-attr="title:close;aria-label:close"><i class="bi bi-x-lg"></i></button>
      </div>
      <form id="weblink-form" autocomplete="off">
        <label class="modal-label" for="weblink-url" data-i18n="weblinks_field_url">URL</label>
        <input id="weblink-url" class="modal-input" type="url" inputmode="url" placeholder="https://example.com" required />
        <label class="modal-label" for="weblink-name" data-i18n="weblinks_field_name">Name</label>
        <input id="weblink-name" class="modal-input" type="text" required />
        <label class="modal-label" for="weblink-category" data-i18n="weblinks_field_category">Category</label>
        <input id="weblink-category" class="modal-input" type="text" />
        <label class="modal-label" for="weblink-description" data-i18n="weblinks_field_description">Description</label>
        <input id="weblink-description" class="modal-input" type="text" />
        <label class="modal-label" for="weblink-username" data-i18n="weblinks_field_username">Username</label>
        <input id="weblink-username" class="modal-input" type="text" autocomplete="off" />
        <label class="modal-label" for="weblink-contact-name" data-i18n="weblinks_field_contact_name">Contact name</label>
        <input id="weblink-contact-name" class="modal-input" type="text" autocomplete="off" />
        <label class="modal-label" for="weblink-contact-phone" data-i18n="weblinks_field_contact_phone">Contact phone</label>
        <input id="weblink-contact-phone" class="modal-input" type="tel" autocomplete="off" />
        <label class="modal-label" for="weblink-contact-email" data-i18n="weblinks_field_contact_email">Contact email</label>
        <input id="weblink-contact-email" class="modal-input" type="email" autocomplete="off" />
        <label class="modal-label" for="weblink-notes" data-i18n="weblinks_field_notes">Notes</label>
        <textarea id="weblink-notes" class="modal-input" rows="3"></textarea>
        <p id="weblink-error" class="modal-error" hidden></p>
        <div class="modal-actions">
          <button id="weblink-cancel" class="btn-ghost" type="button" data-i18n="cancel">Cancel</button>
          <button id="weblink-submit" class="btn-primary" type="submit" data-i18n="save">Save</button>
        </div>
      </form>
    </div>
  </div>

  <% if (typeof userStorageEnabled !== 'undefined' && userStorageEnabled && !storageConfigured) { %>
  <div id="storage-setup-overlay" class="modal-overlay">
    <div class="modal" role="dialog" aria-modal="true" aria-labelledby="storage-setup-title">
      <h3 id="storage-setup-title" class="modal-title"><i class="bi bi-hdd-network"></i> <span data-i18n="storage_setup_title">Connect your storage</span></h3>
      <p class="modal-message" data-i18n="storage_setup_msg">You haven't connected a storage provider yet. Connect one to start saving your encrypted notes — you don't need to register again.</p>
      <div class="modal-actions">
        <button id="storage-setup-btn" class="btn-primary" type="button" data-i18n="storage_setup_btn">Set up storage</button>
      </div>
    </div>
  </div>
  <% } %>

  <script src="/public/js/crypto.js?v=<%= v %>"></script>
  <script src="/public/js/storage-form.js?v=<%= v %>"></script>
  <script src="/public/js/markdown-bundle.js?v=<%= v %>"></script>
  <script src="/public/js/zip-bundle.js?v=<%= v %>"></script>
  <script src="/public/js/upload-bundle.js?v=<%= v %>"></script>
  <script src="/public/js/app.js?v=<%= v %>"></script>
</body>
</html>
