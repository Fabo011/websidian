<!DOCTYPE html>
<html lang="en">
<head>
  <%- include('partials/head', { title: 'websidian' }) %>
  <link rel="stylesheet" href="/public/js/excalidraw-bundle.css" />
</head>
<body class="app" data-username="<%= username %>">
  <header class="topbar">
    <button id="sidebar-toggle" class="icon-btn" aria-label="Toggle sidebar" data-i18n-attr="aria-label:toggle_sidebar"><i class="bi bi-list"></i></button>
    <span class="brand"><i class="bi bi-journal-text"></i> websidian</span>
    <div class="search-wrap">
      <i class="bi bi-search search-icon"></i>
      <input id="search-input" type="search" placeholder="Search notes…" autocomplete="off" data-i18n-attr="placeholder:search_placeholder" />
      <div id="search-results" class="search-results" hidden></div>
    </div>
    <div class="topbar-right">
      <button id="theme-toggle" class="icon-btn" title="Toggle light/dark" data-i18n-attr="title:toggle_theme"><i class="bi bi-circle-half"></i></button>
      <button id="account-btn" class="user" title="Account & storage" data-i18n-attr="title:account_storage"><i class="bi bi-person-circle"></i> <span class="user-name"><%= username %></span></button>
      <button id="logout-btn" class="btn-ghost"><i class="bi bi-box-arrow-right"></i> <span class="btn-label" data-i18n="logout">Logout</span></button>
    </div>
  </header>

  <div class="layout">
    <aside class="sidebar" id="sidebar">
      <div class="sidebar-tools">
        <button id="new-note" title="Create a new markdown note" data-i18n-attr="title:title_new_note"><i class="bi bi-file-earmark-plus"></i> <span data-i18n="tool_note">Note</span></button>
        <button id="new-file" title="Create a new Excalidraw drawing" data-i18n-attr="title:title_new_file"><i class="bi bi-pencil-square"></i> <span data-i18n="tool_file">Drawing</span></button>
        <button id="new-folder" title="Create a new folder" data-i18n-attr="title:title_new_folder"><i class="bi bi-folder-plus"></i> <span data-i18n="tool_folder">Folder</span></button>
        <button id="weblinks-btn" title="Open the web link manager" data-i18n-attr="title:title_weblinks"><i class="bi bi-link-45deg"></i> <span data-i18n="tool_weblinks">Web links</span></button>
        <button id="upload-btn" title="Upload files from your computer" data-i18n-attr="title:title_upload"><i class="bi bi-file-earmark-arrow-up"></i> <span data-i18n="tool_upload">Upload files</span></button>
        <button id="import-btn" title="Import folders or a whole vault (.zip)" data-i18n-attr="title:title_import"><i class="bi bi-folder-symlink"></i> <span data-i18n="tool_import">Import folder</span></button>
        <button id="export-btn" title="Download the whole vault as a .zip" data-i18n-attr="title:title_export"><i class="bi bi-download"></i> <span data-i18n="tool_export">Export</span></button>
      </div>
      <div id="selected-folder" class="selected-folder breadcrumb" aria-label="Selected folder" data-i18n-attr="aria-label:selected_folder"></div>
      <nav id="tree" class="tree" aria-label="Files" data-i18n-attr="aria-label:files_aria"></nav>
    </aside>

    <div class="sidebar-backdrop" id="sidebar-backdrop" hidden></div>

    <main class="content" id="content">
      <div class="welcome" id="welcome">
        <h2><i class="bi bi-journal-richtext"></i> <span data-i18n="welcome">Welcome</span></h2>
        <p data-i18n="welcome_text">Select a note from the sidebar, or create a new one.</p>
      </div>

      <section id="editor-view" class="view" hidden>
        <div class="view-header">
          <button class="icon-btn mobile-back" data-mobile-back title="Show files" aria-label="Show files" data-i18n-attr="title:open_files_title;aria-label:open_files"><i class="bi bi-list"></i></button>
          <span id="current-path" class="current-path breadcrumb"></span>
          <div class="view-actions">
            <button id="toggle-preview" class="btn-ghost" title="Switch between editing and reading" data-i18n-attr="title:title_toggle_view">
              <i class="bi bi-eye"></i> <span class="btn-label">View</span>
            </button>
            <button id="save-btn" class="btn-primary"><i class="bi bi-save"></i> <span class="btn-label" data-i18n="save">Save</span></button>
          </div>
        </div>
        <div class="editor-body" id="editor-body">
          <div id="editor-toolbar" class="editor-toolbar" hidden role="toolbar" aria-label="Markdown formatting">
            <button type="button" class="md-btn" data-md="bold" title="Bold — wrap text in ** ** · e.g. **important**" data-i18n-attr="title:md_bold_tip;aria-label:md_bold_tip" aria-label="Bold">
              <i class="bi bi-type-bold"></i>
            </button>
            <div class="md-dropdown">
              <button type="button" class="md-btn" data-md-heading-toggle aria-haspopup="true" aria-expanded="false" title="Heading — pick a level (#, ##, …) · e.g. # Title" data-i18n-attr="title:md_heading_tip;aria-label:md_heading_tip" aria-label="Heading">
                <i class="bi bi-type-h1"></i> <i class="bi bi-caret-down-fill md-caret"></i>
              </button>
              <div id="md-heading-menu" class="md-menu" hidden>
                <button type="button" class="md-menu-item" data-md="h1"><span><i class="bi bi-type-h1"></i> Heading 1</span><span class="md-sample">#</span></button>
                <button type="button" class="md-menu-item" data-md="h2"><span><i class="bi bi-type-h2"></i> Heading 2</span><span class="md-sample">##</span></button>
                <button type="button" class="md-menu-item" data-md="h3"><span><i class="bi bi-type-h3"></i> Heading 3</span><span class="md-sample">###</span></button>
                <button type="button" class="md-menu-item" data-md="h4"><span><i class="bi bi-type-h4"></i> Heading 4</span><span class="md-sample">####</span></button>
                <button type="button" class="md-menu-item" data-md="h5"><span><i class="bi bi-type-h5"></i> Heading 5</span><span class="md-sample">#####</span></button>
                <button type="button" class="md-menu-item" data-md="h6"><span><i class="bi bi-type-h6"></i> Heading 6</span><span class="md-sample">######</span></button>
              </div>
            </div>
            <button type="button" class="md-btn" data-md="list" title="Bullet list — start a line with &quot;- &quot; · e.g. - item" data-i18n-attr="title:md_list_tip;aria-label:md_list_tip" aria-label="Bullet list">
              <i class="bi bi-list-ul"></i>
            </button>
            <button type="button" class="md-btn" data-md="checklist" title="Task list — start a line with &quot;- [ ] &quot; · e.g. - [ ] to do" data-i18n-attr="title:md_check_tip;aria-label:md_check_tip" aria-label="Task list">
              <i class="bi bi-check2-square"></i>
            </button>
            <button type="button" class="md-btn" data-md="image" title="Embed image — ![[file]] · e.g. ![[diagram.png]]" data-i18n-attr="title:md_image_tip;aria-label:md_image_tip" aria-label="Embed image">
              <i class="bi bi-image"></i>
            </button>
            <button type="button" class="md-btn" data-md="wikilink" title="Internal link — [[Note]] · e.g. [[The System]]" data-i18n-attr="title:md_wikilink_tip;aria-label:md_wikilink_tip" aria-label="Internal link">
              <i class="bi bi-link-45deg"></i>
            </button>
          </div>
          <div class="editor-surface">
            <textarea id="editor" spellcheck="false" placeholder="# Start writing…"></textarea>
            <div id="preview" class="preview markdown" hidden></div>
          </div>
        </div>
      </section>

      <section id="viewer-view" class="view" hidden>
        <div class="view-header">
          <button class="icon-btn mobile-back" data-mobile-back title="Show files" aria-label="Show files" data-i18n-attr="title:open_files_title;aria-label:open_files"><i class="bi bi-list"></i></button>
          <span id="viewer-path" class="current-path breadcrumb"></span>
          <div class="view-actions">
            <a id="viewer-download" class="btn-ghost" download><i class="bi bi-download"></i> <span class="btn-label" data-i18n="download">Download</span></a>
          </div>
        </div>
        <div id="viewer-body" class="viewer-body"></div>
      </section>

      <section id="excalidraw-view" class="view" hidden>
        <div class="view-header">
          <button class="icon-btn mobile-back" data-mobile-back title="Show files" aria-label="Show files" data-i18n-attr="title:open_files_title;aria-label:open_files"><i class="bi bi-list"></i></button>
          <span id="excalidraw-path" class="current-path breadcrumb"></span>
          <div class="view-actions">
            <button id="excalidraw-save" class="btn-primary"><i class="bi bi-save"></i> <span class="btn-label" data-i18n="save">Save</span></button>
          </div>
        </div>
        <div id="excalidraw-root" class="excalidraw-root"></div>
      </section>

      <section id="weblinks-view" class="view" hidden>
        <div class="view-header">
          <button class="icon-btn mobile-back" data-mobile-back title="Show files" aria-label="Show files" data-i18n-attr="title:open_files_title;aria-label:open_files"><i class="bi bi-list"></i></button>
          <span class="current-path breadcrumb"><i class="bi bi-link-45deg"></i> <span data-i18n="weblinks_title">Web links</span> <span class="weblinks-path">weblinks/weblinks.csv</span></span>
          <div class="view-actions">
            <span id="weblinks-count" class="weblinks-count"></span>
          </div>
        </div>
        <div class="weblinks-toolbar" role="toolbar" aria-label="Web links actions">
          <button type="button" id="weblink-add" class="md-btn" title="Add a new web link" data-i18n-attr="title:weblinks_add_tip">
            <i class="bi bi-plus-lg"></i> <span data-i18n="weblinks_add">Add link</span>
          </button>
          <button type="button" id="weblink-import" class="md-btn" title="Import links from a CSV file (Linky format supported)" data-i18n-attr="title:weblinks_import_tip">
            <i class="bi bi-filetype-csv"></i> <span data-i18n="weblinks_import">Import CSV</span>
          </button>
          <div class="weblinks-search-wrap">
            <i class="bi bi-search"></i>
            <input id="weblinks-search" type="search" autocomplete="off" placeholder="Search links…" data-i18n-attr="placeholder:weblinks_search" />
          </div>
        </div>
        <div class="weblinks-body">
          <p class="weblinks-intro" data-i18n="weblinks_intro">Save links once, then always reach them from your vault. Useful so you never forget a link again — and safer too: evaluate a link a single time, store it, and you always open exactly that link instead of a manipulated one.</p>
          <div id="weblinks-list" class="weblinks-list"></div>
          <div id="weblinks-empty" class="weblinks-empty" hidden>
            <i class="bi bi-link-45deg"></i>
            <p data-i18n="weblinks_none">No web links yet. Add one or import a CSV.</p>
          </div>
        </div>
      </section>
    </main>
  </div>

  <div id="context-menu-backdrop" class="context-menu-backdrop" hidden></div>
  <div id="context-menu" class="context-menu" hidden>
    <button data-action="rename"><i class="bi bi-pencil"></i> <span data-i18n="rename">Rename</span></button>
    <button data-action="new-note" data-folder-only><i class="bi bi-file-earmark-plus"></i> <span data-i18n="ctx_new_note">New note</span></button>
    <button data-action="new-file" data-folder-only><i class="bi bi-pencil-square"></i> <span data-i18n="ctx_new_file">New drawing</span></button>
    <button data-action="new-folder" data-folder-only><i class="bi bi-folder-plus"></i> <span data-i18n="ctx_new_folder">New folder</span></button>
    <button data-action="upload" data-folder-only><i class="bi bi-file-earmark-arrow-up"></i> <span data-i18n="ctx_upload">Upload files here</span></button>
    <button data-action="import" data-folder-only><i class="bi bi-folder-symlink"></i> <span data-i18n="ctx_import">Import folder here</span></button>
    <div class="context-menu-sep" data-folder-only></div>
    <button data-action="delete"><i class="bi bi-trash"></i> <span data-i18n="delete">Delete</span></button>
  </div>

  <div id="modal-overlay" class="modal-overlay" hidden>
    <div class="modal" role="dialog" aria-modal="true" aria-labelledby="modal-title">
      <h3 id="modal-title" class="modal-title"></h3>
      <p id="modal-message" class="modal-message" hidden></p>
      <input id="modal-input" class="modal-input" type="text" hidden autocomplete="off" />
      <div class="modal-actions">
        <button id="modal-cancel" class="btn-ghost" type="button"></button>
        <button id="modal-ok" class="btn-primary" type="button"></button>
      </div>
    </div>
  </div>

  <div id="change-password-overlay" class="modal-overlay" hidden>
    <div class="modal" role="dialog" aria-modal="true" aria-labelledby="change-password-title">
      <div class="dashboard-head">
        <h3 id="change-password-title" class="modal-title"><i class="bi bi-key"></i> <span data-i18n="change_password">Change password</span></h3>
        <button id="change-password-close" class="icon-btn" title="Close" aria-label="Close" data-i18n-attr="title:close;aria-label:close"><i class="bi bi-x-lg"></i></button>
      </div>
      <p class="modal-message" data-i18n="change_password_hint">Changing your password requires your current password and a code from your authenticator app.</p>
      <form id="change-password-form" autocomplete="off">
        <label class="modal-label" for="cp-current" data-i18n="current_password">Current password</label>
        <input id="cp-current" class="modal-input" type="password" autocomplete="current-password" required />
        <label class="modal-label" for="cp-new" data-i18n="new_password">New password</label>
        <input id="cp-new" class="modal-input" type="password" autocomplete="new-password" minlength="8" required />
        <label class="modal-label" for="cp-confirm" data-i18n="confirm_new_password">Confirm new password</label>
        <input id="cp-confirm" class="modal-input" type="password" autocomplete="new-password" minlength="8" required />
        <label class="modal-label" for="cp-code" data-i18n="totp_code">Authenticator code</label>
        <input id="cp-code" class="modal-input" type="text" inputmode="numeric" pattern="\d{6}" maxlength="6" autocomplete="one-time-code" required />
        <p id="cp-error" class="modal-error" hidden></p>
        <div class="modal-actions">
          <button id="cp-cancel" class="btn-ghost" type="button" data-i18n="cancel">Cancel</button>
          <button id="cp-submit" class="btn-primary" type="submit" data-i18n="change_password">Change password</button>
        </div>
      </form>
    </div>
  </div>

  <div id="reset-totp-overlay" class="modal-overlay" hidden>
    <div class="modal" role="dialog" aria-modal="true" aria-labelledby="reset-totp-title">
      <div class="dashboard-head">
        <h3 id="reset-totp-title" class="modal-title"><i class="bi bi-shield-lock"></i> <span data-i18n="reset_totp">Reset authenticator (2FA)</span></h3>
        <button id="reset-totp-close" class="icon-btn" title="Close" aria-label="Close" data-i18n-attr="title:close;aria-label:close"><i class="bi bi-x-lg"></i></button>
      </div>

      <form id="reset-totp-verify-form" autocomplete="off">
        <p class="modal-message" data-i18n="reset_totp_verify_hint">Confirm it's you with your current password and a code from your <strong>current</strong> authenticator.</p>
        <label class="modal-label" for="rt-current" data-i18n="current_password">Current password</label>
        <input id="rt-current" class="modal-input" type="password" autocomplete="current-password" required />
        <label class="modal-label" for="rt-current-code" data-i18n="rt_current_code">Current authenticator code</label>
        <input id="rt-current-code" class="modal-input" type="text" inputmode="numeric" pattern="\d{6}" maxlength="6" autocomplete="one-time-code" required />
        <p id="rt-verify-error" class="modal-error" hidden></p>
        <div class="modal-actions">
          <button id="rt-verify-cancel" class="btn-ghost" type="button" data-i18n="cancel">Cancel</button>
          <button id="rt-verify-submit" class="btn-primary" type="submit" data-i18n="continue">Continue</button>
        </div>
      </form>

      <form id="reset-totp-confirm-form" autocomplete="off" hidden>
        <p class="modal-message" data-i18n="reset_totp_scan_hint">Scan this QR code with your new authenticator app (or enter the secret manually), then enter a code from it to finish.</p>
        <img id="rt-qr" class="totp-qr" alt="TOTP QR code" />
        <div class="totp-secret">
          <span class="muted" data-i18n="secret">Secret</span>
          <code id="rt-secret"></code>
          <button type="button" id="rt-copy-secret" class="btn-ghost" data-i18n="copy">Copy</button>
        </div>
        <label class="modal-label" for="rt-new-code" data-i18n="rt_new_code">New authenticator code</label>
        <input id="rt-new-code" class="modal-input" type="text" inputmode="numeric" pattern="\d{6}" maxlength="6" autocomplete="one-time-code" required />
        <p id="rt-confirm-error" class="modal-error" hidden></p>
        <div class="modal-actions">
          <button id="rt-confirm-cancel" class="btn-ghost" type="button" data-i18n="cancel">Cancel</button>
          <button id="rt-confirm-submit" class="btn-primary" type="submit" data-i18n="confirm_finish">Confirm &amp; finish</button>
        </div>
      </form>
    </div>
  </div>

  <div id="dashboard-overlay" class="modal-overlay" hidden>
    <div class="modal dashboard" role="dialog" aria-modal="true" aria-labelledby="dashboard-title">
      <div class="dashboard-head">
        <h3 id="dashboard-title" class="modal-title"><i class="bi bi-person-circle"></i> <span data-i18n="account">Account</span></h3>
        <button id="dashboard-close" class="icon-btn" title="Close" aria-label="Close" data-i18n-attr="title:close;aria-label:close"><i class="bi bi-x-lg"></i></button>
      </div>

      <div class="dashboard-section">
        <div class="dashboard-row">
          <span class="dashboard-label" data-i18n="signed_in_as">Signed in as</span>
          <span id="dashboard-username" class="dashboard-value"></span>
        </div>
      </div>

      <div class="dashboard-section">
        <h4 class="dashboard-subtitle"><i class="bi bi-journal-text"></i> <span data-i18n="help">Help</span></h4>
        <p class="dashboard-hint" data-i18n="docs_hint">Learn how syncing, backups, 2FA and encryption work.</p>
        <a class="btn-ghost" href="/docs" target="_blank" rel="noopener"><i class="bi bi-book"></i> <span data-i18n="open_docs">Open documentation</span></a>
      </div>

      <div class="dashboard-section">
        <h4 class="dashboard-subtitle"><i class="bi bi-translate"></i> <span data-i18n="lang_switch">Language</span></h4>
        <div class="dashboard-row">
          <span class="dashboard-label" data-i18n="lang_switch">Language</span>
          <select id="lang-select" class="lang-select" data-lang-switch aria-label="Language" data-i18n-attr="aria-label:lang_switch">
            <option value="en">English</option>
            <option value="de">Deutsch</option>
          </select>
        </div>
      </div>

      <div class="dashboard-section">
        <h4 class="dashboard-subtitle"><i class="bi bi-hdd"></i> <span data-i18n="storage">Storage</span></h4>
        <div class="usage-bar"><div id="usage-fill" class="usage-fill"></div></div>
        <div class="usage-text"><span id="usage-text" data-i18n="loading">Loading…</span></div>
      </div>

      <div class="dashboard-section" id="plan-section" hidden>
        <h4 class="dashboard-subtitle"><i class="bi bi-stars"></i> <span data-i18n="plan">Plan</span></h4>
        <div id="plan-warning" class="plan-warning" hidden></div>
        <div class="dashboard-row">
          <span class="dashboard-label" data-i18n="current_plan">Current plan</span>
          <span id="plan-value" class="dashboard-value">—</span>
        </div>
        <div id="plan-valid-row" class="dashboard-row" hidden>
          <span class="dashboard-label" data-i18n="plan_valid_until">Valid until</span>
          <span id="plan-valid" class="dashboard-value"></span>
        </div>
        <p id="plan-privileged-hint" class="dashboard-hint" data-i18n="plan_privileged_hint" hidden>You have complimentary 20 GB access — no payment required.</p>
        <div id="plan-upgrade" class="plan-options" hidden>
          <button class="btn-primary plan-btn" type="button" data-plan="plus5"><i class="bi bi-arrow-up-circle"></i> <span data-i18n="upgrade_5gb">Upgrade to 5 GB — €42/year</span></button>
          <button class="btn-primary plan-btn" type="button" data-plan="plus20"><i class="bi bi-arrow-up-circle"></i> <span data-i18n="upgrade_20gb">Upgrade to 20 GB — €72/year</span></button>
        </div>
        <button id="manage-billing-btn" class="btn-ghost" type="button" hidden><i class="bi bi-credit-card"></i> <span data-i18n="manage_billing">Manage subscription</span></button>
        <p id="billing-unavailable" class="dashboard-hint" data-i18n="billing_unavailable" hidden>Paid upgrades are currently unavailable.</p>
      </div>

      <div class="dashboard-section">
        <h4 class="dashboard-subtitle"><i class="bi bi-shield-lock"></i> <span data-i18n="security">Security</span></h4>
        <p class="dashboard-hint" data-i18n="change_password_hint">Changing your password requires your current password and a code from your authenticator app.</p>
        <button id="change-password-btn" class="btn-ghost" type="button"><i class="bi bi-key"></i> <span data-i18n="change_password">Change password</span></button>
        <p class="dashboard-hint" data-i18n="reset_totp_hint">Switching to a new phone or authenticator app? Reset your two-factor authentication to pair a new device.</p>
        <button id="reset-totp-btn" class="btn-ghost" type="button"><i class="bi bi-shield-lock"></i> <span data-i18n="reset_totp">Reset authenticator (2FA)</span></button>
      </div>

      <div class="dashboard-section danger-zone">
        <h4 class="dashboard-subtitle"><i class="bi bi-exclamation-triangle"></i> <span data-i18n="danger_zone">Danger zone</span></h4>
        <p class="dashboard-hint" data-i18n="delete_account_hint">Deleting your account permanently removes all your notes, files and account data. This cannot be undone.</p>
        <button id="delete-account-btn" class="btn-danger"><i class="bi bi-trash"></i> <span data-i18n="delete_account">Delete account</span></button>
      </div>
    </div>
  </div>

  <div id="import-overlay" class="modal-overlay" hidden>
    <div class="modal" role="dialog" aria-modal="true" aria-labelledby="import-modal-title">
      <div class="dashboard-head">
        <h3 id="import-modal-title" class="modal-title"><i class="bi bi-folder-symlink"></i> <span data-i18n="import_title">Import folders</span></h3>
        <button id="import-modal-close" class="icon-btn" title="Close" aria-label="Close" data-i18n-attr="title:close;aria-label:close"><i class="bi bi-x-lg"></i></button>
      </div>
      <p class="modal-message" data-i18n="import_choose_hint">Import a whole vault to get started, or add more folders to an existing vault. The folder structure is preserved.</p>
      <div class="import-options">
        <button id="import-zip-choice" class="import-option" type="button">
          <i class="bi bi-file-earmark-zip"></i>
          <span class="import-option-title" data-i18n="import_zip">Zip file</span>
          <span class="import-option-desc" data-i18n="import_zip_desc">Recommended — no browser warning. The archive is unpacked automatically.</span>
        </button>
        <button id="import-folder-choice" class="import-option" type="button">
          <i class="bi bi-folder2-open"></i>
          <span class="import-option-title" data-i18n="import_folder">Folder</span>
          <span class="import-option-desc" data-i18n="import_folder_desc">Your browser will ask you to confirm the folder upload.</span>
        </button>
      </div>
      <p class="muted import-limit-note" data-i18n="import_limit_note">Limits apply to each upload.</p>
    </div>
  </div>

  <input id="upload-input" type="file" hidden multiple />
  <input id="import-input" type="file" hidden multiple />
  <input id="import-zip-input" type="file" hidden accept=".zip,application/zip" />
  <input id="weblinks-import-input" type="file" hidden accept=".csv,text/csv" />

  <div id="weblink-overlay" class="modal-overlay" hidden>
    <div class="modal" role="dialog" aria-modal="true" aria-labelledby="weblink-modal-title">
      <div class="dashboard-head">
        <h3 id="weblink-modal-title" class="modal-title"><i class="bi bi-link-45deg"></i> <span data-i18n="weblinks_add">Add link</span></h3>
        <button id="weblink-modal-close" class="icon-btn" title="Close" aria-label="Close" data-i18n-attr="title:close;aria-label:close"><i class="bi bi-x-lg"></i></button>
      </div>
      <form id="weblink-form" autocomplete="off">
        <label class="modal-label" for="weblink-url" data-i18n="weblinks_field_url">URL</label>
        <input id="weblink-url" class="modal-input" type="url" inputmode="url" placeholder="https://example.com" required />
        <label class="modal-label" for="weblink-name" data-i18n="weblinks_field_name">Name</label>
        <input id="weblink-name" class="modal-input" type="text" required />
        <label class="modal-label" for="weblink-category" data-i18n="weblinks_field_category">Category</label>
        <input id="weblink-category" class="modal-input" type="text" />
        <label class="modal-label" for="weblink-description" data-i18n="weblinks_field_description">Description</label>
        <input id="weblink-description" class="modal-input" type="text" />
        <p id="weblink-error" class="modal-error" hidden></p>
        <div class="modal-actions">
          <button id="weblink-cancel" class="btn-ghost" type="button" data-i18n="cancel">Cancel</button>
          <button id="weblink-submit" class="btn-primary" type="submit" data-i18n="save">Save</button>
        </div>
      </form>
    </div>
  </div>

  <script src="/public/js/crypto.js"></script>
  <script src="/public/js/markdown-bundle.js"></script>
  <script src="/public/js/zip-bundle.js"></script>
  <script src="/public/js/app.js"></script>
</body>
</html>
