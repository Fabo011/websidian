<meta charset="utf-8" />
<meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
<meta name="color-scheme" content="light dark" />
<title><%= typeof title !== 'undefined' ? title : 'websidian' %></title>
<link rel="icon" type="image/svg+xml" href="/public/favicon.svg?v=<%= v %>" />
<link rel="apple-touch-icon" href="/public/websidian-logo.png?v=<%= v %>" />
<link rel="stylesheet" href="/public/vendor/bootstrap-icons/bootstrap-icons.min.css" />
<link rel="stylesheet" href="/public/css/style.css?v=<%= v %>" />
<script>
  // Apply saved theme before paint to avoid a flash.
  (function () {
    try {
      var t = localStorage.getItem('wo-theme');
      if (!t) {
        t = window.matchMedia('(prefers-color-scheme: light)').matches ? 'light' : 'dark';
      }
      document.documentElement.setAttribute('data-theme', t);
    } catch (e) {
      document.documentElement.setAttribute('data-theme', 'dark');
    }
  })();
</script>
<script>
  // Set the document language before paint based on saved/browser preference.
  (function () {
    try {
      var l = localStorage.getItem('wo-lang');
      if (!l) {
        l = (navigator.language || 'en').slice(0, 2).toLowerCase();
      }
      if (l === 'de' || l === 'en') {
        document.documentElement.lang = l;
      }
    } catch (e) {
      /* ignore */
    }
  })();
</script>
<script>
  // Free-tier storage allowance (bytes), set by the server from STORAGE_QUOTA_GB.
  // i18n.js reads this to render the real free quota instead of a hardcoded size.
  window.__WO_FREE_BYTES__ = <%= typeof freeBytes !== 'undefined' ? freeBytes : 0 %>;
  // Import caps, set by the server from MAX_UPLOAD_FILE_MB / MAX_IMPORT_FILES.
  // i18n.js reads these to show the real limits in the Import dialog.
  window.__WO_MAX_UPLOAD_MB__ = <%= typeof maxUploadFileMb !== 'undefined' ? maxUploadFileMb : 0 %>;
  window.__WO_MAX_IMPORT_FILES__ = <%= typeof maxImportFiles !== 'undefined' ? maxImportFiles : 0 %>;
  window.__WO_MAX_IMPORT_TOTAL_MB__ = <%= typeof maxImportTotalMb !== 'undefined' ? maxImportTotalMb : 0 %>;
  // How long (ms) the client reuses a built wikilink graph before rebuilding,
  // set by the server from GRAPH_CACHE_TTL_MS. app.js reads this.
  window.__WO_GRAPH_CACHE_TTL_MS__ = <%= typeof graphCacheTtlMs !== 'undefined' ? graphCacheTtlMs : 0 %>;
  // Max file tabs kept open at once, set by the server from MAX_OPEN_TABS.
  // app.js reads this to cap the tab bar.
  window.__WO_MAX_OPEN_TABS__ = <%= typeof maxOpenTabs !== 'undefined' ? maxOpenTabs : 8 %>;
  // Junk-file glob patterns (macOS ._*, .DS_Store, …), set by the server from
  // UPLOAD_EXCLUDE_PATTERNS. The folder uploader skips matching files.
  window.__WO_UPLOAD_EXCLUDE__ = <%- JSON.stringify(typeof uploadExcludePatterns !== 'undefined' ? uploadExcludePatterns : []) %>;
</script>
<script src="/public/js/i18n.js?v=<%= v %>"></script>
