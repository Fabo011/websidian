<meta charset="utf-8" />
<meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
<meta name="color-scheme" content="light dark" />
<title><%= typeof title !== 'undefined' ? title : 'web-obsidian' %></title>
<link rel="icon" type="image/svg+xml" href="/public/favicon.svg" />
<link rel="apple-touch-icon" href="/public/web-obsidian-logo.png" />
<link rel="stylesheet" href="/public/vendor/bootstrap-icons/bootstrap-icons.min.css" />
<link rel="stylesheet" href="/public/css/style.css" />
<script>
  // Apply saved theme before paint to avoid a flash.
  (function () {
    try {
      var t = localStorage.getItem('wo-theme');
      if (!t) {
        t = window.matchMedia('(prefers-color-scheme: light)').matches ? 'light' : 'dark';
      }
      document.documentElement.setAttribute('data-theme', t);
    } catch (e) {
      document.documentElement.setAttribute('data-theme', 'dark');
    }
  })();
</script>
<script>
  // Set the document language before paint based on saved/browser preference.
  (function () {
    try {
      var l = localStorage.getItem('wo-lang');
      if (!l) {
        l = (navigator.language || 'en').slice(0, 2).toLowerCase();
      }
      if (l === 'de' || l === 'en') {
        document.documentElement.lang = l;
      }
    } catch (e) {
      /* ignore */
    }
  })();
</script>
<script src="/public/js/i18n.js"></script>
