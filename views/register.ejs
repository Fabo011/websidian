<!DOCTYPE html>
<html lang="en">
<head>
  <%- include('partials/head', { title: 'Create account · web-obsidian' }) %>
</head>
<body class="auth-page">
  <main class="auth-card">
    <div class="auth-lang">
      <select class="lang-select" data-lang-switch aria-label="Language" data-i18n-attr="aria-label:lang_switch">
        <option value="en">EN</option>
        <option value="de">DE</option>
      </select>
    </div>
    <h1 class="auth-logo">web-obsidian</h1>

    <form id="register-form" class="auth-form" autocomplete="on">
      <h2 data-i18n="create_account">Create account</h2>
      <label>
        <span data-i18n="username">Username</span>
        <input name="username" type="text" autocomplete="username"
               pattern="[a-zA-Z0-9_-]{3,32}" required />
        <small class="muted" data-i18n="reg_username_hint">3–32 chars: letters, numbers, dashes, underscores.</small>
      </label>
      <label>
        <span data-i18n="password">Password</span>
        <input name="password" type="password" autocomplete="new-password"
               minlength="8" required />
        <small class="muted" data-i18n="reg_password_hint">At least 8 characters.</small>
      </label>
      <p class="form-error" id="register-error" hidden></p>
      <button type="submit" class="btn-primary" data-i18n="create_account">Create account</button>
    </form>

    <section id="enroll-step" class="auth-form" hidden>
      <h2 data-i18n="setup_2fa">Set up two-factor auth</h2>
      <p class="muted" data-i18n="setup_2fa_help">
        Scan the QR code with your authenticator app, or enter the secret manually.
      </p>
      <img id="totp-qr" class="totp-qr" alt="TOTP QR code" />
      <div class="totp-secret">
        <span class="muted" data-i18n="secret">Secret</span>
        <code id="totp-secret"></code>
        <button type="button" id="copy-secret" class="btn-ghost" data-i18n="copy">Copy</button>
      </div>
      <form id="confirm-form">
        <label>
          <span data-i18n="verification_code">Verification code</span>
          <input name="code" type="text" inputmode="numeric" pattern="\d{6}"
                 maxlength="6" autocomplete="one-time-code" required />
        </label>
        <p class="form-error" id="confirm-error" hidden></p>
        <button type="submit" class="btn-primary" data-i18n="confirm_finish">Confirm &amp; finish</button>
      </form>
    </section>

    <section id="plan-step" class="auth-form" hidden>
      <h2 data-i18n="choose_plan">Choose your plan</h2>
      <p class="muted" data-i18n="choose_plan_hint">
        Start free with 1 GB, or upgrade now for more storage. You can change this anytime in your dashboard.
      </p>
      <div class="plan-cards">
        <label class="plan-card">
          <input type="radio" name="plan" value="free" checked />
          <span class="plan-card-title" data-i18n="plan_free_card">Free</span>
          <span class="plan-card-desc" data-i18n="plan_free_desc">1 GB of storage. No payment required.</span>
        </label>
        <label class="plan-card">
          <input type="radio" name="plan" value="plus5" />
          <span class="plan-card-title" data-i18n="plan_5gb_card">5 GB</span>
          <span class="plan-card-desc" data-i18n="plan_5gb_desc">€42 / year (billed annually).</span>
        </label>
        <label class="plan-card">
          <input type="radio" name="plan" value="plus20" />
          <span class="plan-card-title" data-i18n="plan_20gb_card">20 GB</span>
          <span class="plan-card-desc" data-i18n="plan_20gb_desc">€72 / year (billed annually).</span>
        </label>
      </div>
      <p class="form-error" id="plan-error" hidden></p>
      <button type="button" id="plan-continue" class="btn-primary" data-i18n="continue_free">Continue with free 1 GB</button>
    </section>

    <p class="auth-alt"><span data-i18n="have_account">Already have an account?</span> <a href="/login" data-i18n="signin">Sign in</a></p>
  </main>

  <script src="/public/js/auth.js"></script>
</body>
</html>
